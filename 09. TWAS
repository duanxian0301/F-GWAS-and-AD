#!/bin/bash

# Define paths
DATA=/mnt/h/metaxcan/sample_data/data
METAXCAN=/mnt/h/metaxcan/MetaXcan-master/software
OUTPUT=/mnt/h/metaxcan/test
MODEL_DIR=$DATA/models/eqtl/mashr/brain  # Folder containing mashr brain models

# Create output directory
mkdir -p $OUTPUT/spredixcan/eqtl

# Loop through all GWAS input files (post-processed results)
for gwas_file in $OUTPUT/processed_summary_imputation/imputed_*.txt.gz; do
  # Extract GWAS name, e.g., EC / OC / CC
  gwas_name=$(basename "$gwas_file" .txt.gz)
  gwas_name=${gwas_name#imputed_}

  echo "===== Processing GWAS: $gwas_name ====="

  # Loop through all .db model files in the mashr model directory
  for model_db in $MODEL_DIR/*.db; do
    # Extract model name (tissue name)
    model_name=$(basename "$model_db" .db)

    # Set covariance file path
    covariance_file="${MODEL_DIR}/${model_name}.txt.gz"

    # Set output file path
    output_file="$OUTPUT/spredixcan/eqtl/${gwas_name}__PM__${model_name}.csv"

    # Run SPrediXcan analysis
    python3 $METAXCAN/SPrediXcan.py \
      --gwas_file "$gwas_file" \
      --snp_column panel_variant_id \
      --effect_allele_column effect_allele \
      --non_effect_allele_column non_effect_allele \
      --zscore_column zscore \
      --model_db_path "$model_db" \
      --covariance "$covariance_file" \
      --keep_non_rsid \
      --additional_output \
      --model_db_snp_key varID \
      --throw \
      --output_file "$output_file"

    # Check whether the run was successful
    if [ $? -ne 0 ]; then
      echo "Error during SPrediXcan for $gwas_name with model $model_name. Exiting..."
      exit 1
    fi

    echo "Completed: $gwas_name × $model_name"
  done

  echo "===== All tissue models for GWAS $gwas_name have been completed ====="
done

echo "All SPrediXcan jobs for all GWAS × all tissues have been completed!"

