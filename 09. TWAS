#!/bin/bash

# Define paths
DATA=/mnt/h/metaxcan/sample_data/data
METAXCAN=/mnt/h/metaxcan/MetaXcan-master/software
OUTPUT=/mnt/h/metaxcan/test

# Create output directory
mkdir -p $OUTPUT/smultixcan/eqtl

# Loop through all imputed GWAS files
for gwas_file in $OUTPUT/processed_summary_imputation/imputed_*.txt.gz; do
  # Extract GWAS name (e.g., imputed_EC -> EC)
  gwas_name=$(basename "$gwas_file" .txt.gz)
  gwas_name=${gwas_name#imputed_}

  echo "===== Running SMulTiXcan: $gwas_name ====="

  python3 $METAXCAN/SMulTiXcan.py \
    --models_folder $DATA/models/eqtl/mashr/brain \
    --models_name_pattern "mashr_(.*).db" \
    --snp_covariance $DATA/models/gtex_v8_expression_mashr_snp_smultixcan_covariance.txt.gz \
    --metaxcan_folder $OUTPUT/spredixcan/eqtl \
    --metaxcan_filter "${gwas_name}__PM__mashr_(.*).csv" \
    --metaxcan_file_name_parse_pattern "(.*)__PM__mashr_(.*).csv" \
    --gwas_file "$gwas_file" \
    --snp_column panel_variant_id \
    --effect_allele_column effect_allele \
    --non_effect_allele_column non_effect_allele \
    --zscore_column zscore \
    --keep_non_rsid \
    --model_db_snp_key varID \
    --cutoff_condition_number 30 \
    --verbosity 7 \
    --throw \
    --output "$OUTPUT/smultixcan/eqtl/${gwas_name}_smultixcan.txt"

  if [ $? -ne 0 ]; then
    echo "❌ Error running SMulTiXcan for $gwas_name"
    exit 1
  fi

  echo "✅ Completed SMulTiXcan: $gwas_name"
done

echo "🎉 SMulTiXcan analysis for all GWAS files has been completed!"
