# GWAS summary statistics should undergo standard quality control before PLACO+ analysis
library(devtools)
library(data.table)
source("H:/PLACO+/PLACO-master/PLACO_v0.2.0.R")

# Read input data
gwas1 <- fread("AD.txt")
gwas2 <- fread("F4.txt")

# Construct PLACO+ input matrices
Z.matrix <- cbind(gwas1$Z, gwas2$Z)
P.matrix <- cbind(gwas1$p, gwas2$p)
colnames(Z.matrix) <- c("Z1", "Z2")
colnames(P.matrix) <- c("P1", "P2")

# Filter extreme statistics
Z1_sq <- Z.matrix[,1]^2
Z2_sq <- Z.matrix[,2]^2
keep <- (Z1_sq <= 80) & (Z2_sq <= 80)
Z.matrix <- Z.matrix[keep, ]
P.matrix <- P.matrix[keep, ]

# Estimate parameters
VarZ <- var.placo(Z.matrix, P.matrix, p.threshold = 1e-4)
CorZ <- cor.pearson(Z.matrix, P.matrix, p.threshold = 1e-4, returnMatrix = FALSE)

# Run PLACO+
placo_out <- lapply(1:nrow(Z.matrix), function(i) {
  placo.plus(Z = Z.matrix[i, ], VarZ = VarZ, CorZ = CorZ)
})

# Save results
results <- data.frame(
  T_placo = sapply(placo_out, function(x) x$T.placo.plus),
  P_placo = sapply(placo_out, function(x) x$p.placo.plus)
)

write.table(results, "PLACO_plus_results.txt", sep = "\t", row.names = FALSE, quote = FALSE)
