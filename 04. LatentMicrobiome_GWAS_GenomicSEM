Akkermansiaid4037 ~~ e11*Akkermansiaid4037
e11 > .0001
"


# ---------- output ----------
dirs <- c("output/F1", "output/F2", "output/F3", "output/F4")
sapply(dirs, function(x) if (!dir.exists(x)) dir.create(x, recursive = TRUE))

# ---------- Start looping ----------
for (i in 1:59) {
  cat("\n==============================\n")
  cat("▶ Running partition:", i, "of 59\n")
  cat("==============================\n")
  
  input_file <- paste0("input/GenSem_sub_par", i, "_cancigalc")
  
  # cheak sumstats
  if (!file.exists(input_file)) {
    cat("⚠️ File not found:", input_file, "\n")
    next
  }
  
  # read sumstats
  sumstats <- tryCatch({
    fread(input_file)
  }, error = function(e) {
    cat("❌ Error reading file:", input_file, "\n")
    print(e)
    return(NULL)
  })
  
  if (is.null(sumstats)) next
  
  # ---------- Run userGWAS ----------
  result <- tryCatch({
    userGWAS(
      covstruc = LDSCoutput,
      SNPs = sumstats,
      estimation = "DWLS",
      model = model,
      printwarn = TRUE,
      sub = c("F1~SNP", "F2~SNP", "F3~SNP", "F4~SNP"),
      cores = 8,
      toler = 1e-50,
      parallel = TRUE,
      GC = "none",
      MPI = FALSE,
      smooth_check = TRUE,
      fix_measurement = TRUE,
      Q_SNP = TRUE
    )
  }, error = function(e) {
    cat("❌ Model failed for partition", i, "\n")
    print(e)
    return(NULL)
  })
  
  if (is.null(result)) next
  
  # ---------- Save result ----------
  tryCatch({
    fwrite(as.data.frame(result[[1]]), paste0("output/F1/F1-", i, ".txt"), sep = "\t")
    fwrite(as.data.frame(result[[2]]), paste0("output/F2/F2-", i, ".txt"), sep = "\t")
    fwrite(as.data.frame(result[[3]]), paste0("output/F3/F3-", i, ".txt"), sep = "\t")
    fwrite(as.data.frame(result[[4]]), paste0("output/F4/F4-", i, ".txt"), sep = "\t")
  }, error = function(e) {
    cat("⚠️ Failed to write output for partition", i, "\n")
    print(e)
  })
  
  cat("✅ Partition", i, "completed.\n")
}


